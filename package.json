{
  "name": "frontend-conqueror",
  "version": "0.11.0",
  "private": true,
  "description": "Edit text in your dev site. Drop TODOs from the browser. Let testers file Linear issues from production. Three modes, one overlay, no server lock-in.",
  "license": "MIT",
  "homepage": "https://github.com/jwan99/frontend-conqueror",
  "workspaces": [
    "plugin",
    "agent",
    "gate"
  ],
  "exports": {
    "./plugin": "./plugin/index.js",
    "./agent": "./agent/server.js",
    "./gate": "./gate/server.js",
    "./overlay.js": "./overlay/overlay.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "frontend-conqueror": "./bin/fc.js"
  },
  "files": [
    "bin",
    "plugin",
    "agent",
    "gate",
    "overlay",
    "CHANGELOG.md",
    "STACKS.md",
    "CHECKLIST.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "agent": "node agent/server.js",
    "gate": "node gate/server.js"
  },
  "keywords": [
    "vite-plugin",
    "nuxt",
    "in-context-editing",
    "i18n",
    "linear",
    "bug-reporting",
    "qa",
    "developer-tools"
  ]
}