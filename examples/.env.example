# frontend-conqueror gate environment.
# Copy this to /etc/frontend-conqueror-gate.env (or your secret store) and fill in.
# DO NOT commit the filled-in version anywhere.

# The default admin password shown on the login page until first change.
# Generate with: openssl rand -hex 12
GATE_ADMIN_PASSWORD=replace-me

# Signing key for admin sessions and tester JWTs. Rotating this instantly
# invalidates every active session. Use 32+ random bytes.
# Generate with: openssl rand -hex 32
GATE_JWT_SECRET=replace-me-32-bytes-hex

# OPTIONAL overrides — defaults are usually fine:
# GATE_PORT=54322
# GATE_HOST=127.0.0.1
# GATE_PUBLIC_URL=https://gate.my-domain.com
# GATE_PROJECT_NAME=my-app
# GATE_DATA=/var/data/my-app-gate.json
# GATE_JWT_TTL=86400          # tester session: 24h default
# GATE_ADMIN_TTL=43200        # admin session: 12h default